            "label": "2026-05-19_09-53-39",
            "content": "package main\nimport \"fmt\"\n\nfunc valido(s []rune, pos int, valor int, L int) bool {\n\n\tn := len(s)\n\n\tfor i := pos - L; i <= pos+L; i++ {\n\n\t\tif i < 0 || i >= n || i == pos {\n\t\t\tcontinue\n\t\t}\n\n\t\tif s[i] != '.' && int(s[i]-'0') == valor {\n\t\t\treturn false\n\t\t}\n\t}\n\n\treturn true\n}\n\nfunc resolver(s []rune, L int, pos int) bool {\n    if pos == len(s) {\n        return true\n    }\n    if s[pos] != '.' {\n        return resolver(s, L, pos + 1)\n    }\n    for d := 0; d <= L; d++ {\n\n        if valido(s, pos, d, L) {\n            s[pos] = rune(d + '0')\n\n            if resolver(s, L, pos + 1) {\n                return true\n            }\n            s[pos] = '.'\n        }\n    }\n    return false\n}\n\nfunc main() {\n\n\tvar entrada string\n\tvar L int\n\n\tfmt.Scan(&entrada)\n\tfmt.Scan(&L)\n\n\ts := []rune(entrada)\n\n    resolver(s, L, 0)\n\n    fmt.Println(string(s))\n\n\t\n}\n",
